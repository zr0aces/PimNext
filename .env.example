# ─────────────────────────────────────────────────────────────────────────────
# PrintBot – Environment Configuration Example
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────

# Telegram Bot API token
# Get one from @BotFather: https://t.me/BotFather
TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZ

# CUPS server hostname or IP address (the host running CUPS on port 631)
# Examples: CUPS_SERVER=cups  |  CUPS_SERVER=192.168.1.100
CUPS_SERVER=cups

# Printer name as registered in CUPS
# Run `lpstat -v -h <CUPS_SERVER>` to list available printers.
PRINTER_NAME=Canon_LBP7110Cw

# ── Access Control ────────────────────────────────────────────────────────────

# Comma-separated list of Telegram chat IDs allowed to print and use /clean
# Find your chat ID via @userinfobot: https://t.me/userinfobot
# If left blank, ANY Telegram user can send files to your printer!
ALLOWED_CHAT_IDS=123456789,987654321

# ── Optional ─────────────────────────────────────────────────────────────────

# Log verbosity: DEBUG | INFO | WARNING | ERROR  (default: INFO)
# LOG_LEVEL=INFO

# Timezone for container log timestamps (default: UTC)
# TZ=Asia/Bangkok

# Home Assistant integration (optional)
# If both HA_URL and HA_TOKEN are set, PrintBot fires a `printbot_job_sent`
# event in Home Assistant after each successful print.
# HA_URL=http://homeassistant:8123
# HA_TOKEN=your_long_lived_access_token
