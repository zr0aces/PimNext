# Telegram Bot API token (required)
# Get one from @BotFather: https://t.me/BotFather
TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZ

# Comma-separated list of Telegram chat IDs allowed to use the bot (optional)
# Chat IDs are permanent numeric identifiers — unlike usernames they cannot be
# changed or spoofed, making them the recommended way to restrict access.
# If unset, ALL Telegram users can interact with the bot.
# To find your chat ID, send a message to @userinfobot on Telegram.
ALLOWED_CHAT_IDS=123456789,987654321
