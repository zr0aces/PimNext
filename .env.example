# Telegram Bot API token (required)
# Get one from @BotFather: https://t.me/BotFather
TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZ

# Comma-separated list of Telegram chat IDs allowed to use the bot (optional)
ALLOWED_CHAT_IDS=123456789,987654321

# CUPS server address (required for external containers)
# Set this to the hostname or IP of your CUPS container/server
# Example: CUPS_SERVER=192.168.1.100 or CUPS_SERVER=cups
CUPS_SERVER=cups

# Specific printer IP & name (optional)
# If unset, CUPS will use the server's default printer.
# Use 'lpstat -v' or the CUPS web UI to find printer names.
PRINTER_IP=192.168.1.100
PRINTER_NAME=Canon_LBP7110Cw

# Home Assistant webhook (optional)
# If both are set, PrintBot fires a printbot_job_sent event after each print.
# HA_URL=http://homeassistant:8123
# HA_TOKEN=your_long_lived_access_token
